# Copy to .env and fill in. NEVER commit your real .env.
# Leave keys blank to run fully offline against fixtures (recommended for judges).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: enables live YouTube transcript fetching. Omit to use fixtures.
YOUTUBE_API_KEY=

# Force offline/fixture mode regardless of keys (1 = offline).
DRAGONGUIDE_OFFLINE=0
